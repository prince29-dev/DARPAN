# Delhi Open Transit Data (OTD) — GTFS-Realtime API key.
# Request a key at https://otd.delhi.gov.in and paste it below.
# Never commit the real value — this file only documents the variable name.
# Server-only (no NEXT_PUBLIC_ prefix): the key is used exclusively by
# services/realtime/otd-feed-client.ts on the server, and is never sent to
# the browser. See docs/ARCHITECTURE.md § Milestone 6 for why.
OTD_API_KEY=

# Optional overrides — sensible defaults are baked into config/realtime.ts.
# OTD_VEHICLE_POSITIONS_URL=https://otd.delhi.gov.in/api/realtime/VehiclePositions.pb
